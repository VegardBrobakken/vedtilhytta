rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Items for sale: anyone can read; only signed-in users can write.
    match /items/{item} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: anyone may create one from the public order form (guarded by
    // field validation), but only signed-in admins can read, update or delete.
    match /orders/{order} {
      allow read, update, delete: if request.auth != null;
      allow create: if isValidOrder();
    }
  }

  function isValidOrder() {
    let d = request.resource.data;
    return d.keys().hasOnly(['name', 'email', 'phone', 'address', 'products', 'status', 'createdAt'])
      && d.name is string     && d.name.size() > 0     && d.name.size() < 200
      && d.email is string    && d.email.size() > 0     && d.email.size() < 200
      && d.phone is string    && d.phone.size() > 0     && d.phone.size() < 100
      && d.address is string  && d.address.size() < 1000
      && d.products is string && d.products.size() > 0  && d.products.size() < 4000
      && d.status == 'new'
      && d.createdAt == request.time;
  }
}
