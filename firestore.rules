rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Items for sale: anyone can read; only signed-in users can write.
    match /items/{item} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: anyone may create one from the public order form (guarded by
    // field validation), but only signed-in admins can read, update or delete.
    match /orders/{order} {
      allow read, update, delete: if request.auth != null;
      allow create: if isValidOrder();
    }

    // Order-number counter: readable by anyone (the public order form reads it
    // to work out the next number) and publicly writable only in the tightly
    // constrained way the order form does it — created at the first number, or
    // incremented by exactly one. Admins may read it too.
    match /counters/orders {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['value'])
        && request.resource.data.value == 1000;
      allow update: if request.resource.data.keys().hasOnly(['value'])
        && request.resource.data.value == resource.data.value + 1;
      allow delete: if false;
    }
  }

  function isValidOrder() {
    let d = request.resource.data;
    return d.keys().hasOnly(['name', 'email', 'phone', 'address', 'products', 'status', 'createdAt', 'orderNumber'])
      && d.name is string     && d.name.size() > 0     && d.name.size() < 200
      && d.email is string    && d.email.size() > 0     && d.email.size() < 200
      && d.phone is string    && d.phone.size() > 0     && d.phone.size() < 100
      && d.address is string  && d.address.size() < 1000
      && d.products is string && d.products.size() > 0  && d.products.size() < 4000
      && d.orderNumber is int && d.orderNumber >= 1000
      && d.status == 'new'
      && d.createdAt == request.time;
  }
}
