# Firebase web config (safe to expose to the client, but kept in env for portability).
# Copy this file to .env.local and fill in values from your Firebase project settings.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Web3Forms access key for the order form. Get one at https://web3forms.com
# by entering the email address that should receive orders. Safe to expose.
VITE_WEB3FORMS_ACCESS_KEY=
